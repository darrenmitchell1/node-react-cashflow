{
  "name": "node-react-base",
  "private": true,
  "version": "1.0.0",
  "description": "This project is a base for a monolithic repository that consists of both Next.js and NestJS apps.",
  "keywords": [],
  "author": "Darren Mitchell",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "main": "index.js",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:backend": "cd apps/backend && npm run start:dev",
    "dev:frontend": "cd apps/frontend && npm run dev",
    "test": "echo \"Error: no test specified\" && exit 1",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/pg": "^8.20.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.35",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5",
    "prettier": "^3",
    "typescript": "^5",
    "typescript-eslint": "^7"
  },
  "dependencies": {
    "@nestjs/typeorm": "^11.0.1",
    "pg": "^8.21.0",
    "typeorm": "^1.0.0"
  }
}
